#include "cxxtest/TestSuite.h"

#include "test55/prot/Message.h"
#include "test55/prot/frame/Frame.h"

#include "test55/wrap/Message.h"
#include "test55/wrap/frame/WrapFrame.h"

#include "comms/process.h"

#include <cstdint>
#include <type_traits>

class TestSuite : public CxxTest::TestSuite
{
public:
    void test1();
    void test2();

    using WrapInterface = test55::wrap::Message<>;
    using WrapFrame = test55::wrap::frame::WrapFrame<WrapInterface>;

    using Interface = test55::prot::Message<
        comms::option::app::IdInfoInterface,
        comms::option::app::LengthInfoInterface,
        comms::option::app::ReadIterator<const std::uint8_t*>,
        comms::option::app::WriteIterator<std::uint8_t*>,
        comms::option::app::NameInterface
    >;
    using Frame = test55::prot::frame::Frame<Interface>;

    TEST55_WRAP_ALIASES_FOR_ALL_MESSAGES_DEFAULT_OPTIONS(Wrap,,WrapInterface);
    TEST55_PROT_ALIASES_FOR_ALL_MESSAGES_DEFAULT_OPTIONS(Prot,,Interface);

    void postProcessRead(std::vector<std::uint8_t>& vec)
    {
        bool keepNextByte = false;
        vec.erase(
            std::remove_if(
                vec.begin(), vec.end(),
                [&vec, &keepNextByte](std::uint8_t& byte)
                {
                    if (keepNextByte) {
                        keepNextByte = false;
                        return false;
                    }

                    if (byte != test55::wrap::field::EscFieldCommon::valueVal()) {
                        return false;
                    }

                    auto currIdx = static_cast<unsigned>(std::distance(vec.data(), &byte));
                    if (vec.size() <= (currIdx + 1U)) {
                        return false;
                    }

                    auto nextByte = vec[currIdx + 1U];
                    if ((nextByte != 0x02) && (nextByte != 0x03) && (nextByte != test55::wrap::field::EscFieldCommon::valueVal())) {
                        return false;
                    }

                    keepNextByte = true;
                    return true;
                }),
            vec.end());
    }

    template <typename TVec>
    void postProcessWrite(TVec& vec)
    {
        TVec output;
        for (auto byte : vec) {
            if ((byte == 0x02) || (byte == 0x03) || (byte == test55::wrap::field::EscFieldCommon::valueVal())) {
                output.push_back(test55::wrap::field::EscFieldCommon::valueVal());
            }
            output.push_back(byte);
        }

        vec.swap(output);
    }
};

void TestSuite::test1()
{
    const std::uint8_t Buf[] = {
        0x11, 0x12, 0x33, // Garbage
        0x02, // Prefix
        static_cast<std::uint8_t>(test55::prot::MsgId_M2),
        'h', 'e', 'l', 'l', 'o',
        0x03 // Suffix
    };
    const std::size_t BufSize = std::extent<decltype(Buf)>::value;

    WrapPseudoMsg pseudoMsg;
    WrapFrame wrapFrame;

    auto readIter = &Buf[0];
    auto es = wrapFrame.read(pseudoMsg, readIter, BufSize);
    TS_ASSERT_EQUALS(es, comms::ErrorStatus::Success);
    auto& dataVec = pseudoMsg.field_data().value();
    postProcessRead(dataVec);

    Frame frame;
    Frame::MsgPtr msgPtr;

    auto iter = comms::readIteratorFor<Interface>(dataVec.data());
    es = frame.read(msgPtr, iter, dataVec.size());
    TS_ASSERT_EQUALS(es, comms::ErrorStatus::Success);
    TS_ASSERT(msgPtr);
    TS_ASSERT_EQUALS(msgPtr->getId(), test55::prot::MsgId_M2);

    auto* msg2 = static_cast<const ProtMsg2*>(msgPtr.get());
    TS_ASSERT_EQUALS(msg2->field_f1().value(), "hello");

    std::vector<std::uint8_t> outputBuf;
    outputBuf.resize(frame.length(*msg2));
    auto writeIter = comms::writeIteratorFor<Interface>(outputBuf.data());
    es = frame.write(*msgPtr, writeIter, outputBuf.size());
    TS_ASSERT_EQUALS(es, comms::ErrorStatus::Success);

    postProcessWrite(outputBuf);
    comms::util::assign(pseudoMsg.field_data().value(), outputBuf.begin(), outputBuf.end());

    std::vector<std::uint8_t> finalOutputBuf;
    auto finalWriteIter = std::back_inserter(finalOutputBuf);
    es = wrapFrame.write(pseudoMsg, finalWriteIter, finalOutputBuf.max_size());
    if (es == comms::ErrorStatus::UpdateRequired) {
        auto updateIter = finalOutputBuf.data();
        es = wrapFrame.update(pseudoMsg, updateIter, finalOutputBuf.size());
    }
    TS_ASSERT_EQUALS(es, comms::ErrorStatus::Success);

    TS_ASSERT(std::equal(finalOutputBuf.begin(), finalOutputBuf.end(), std::begin(Buf) + 3U));
}

void TestSuite::test2()
{
    const std::uint8_t Buf[] = {
        0x11, 0x12, 0x33, // Garbage
        0x02, // Prefix
        static_cast<std::uint8_t>(test55::prot::MsgId_M1),
        0x10 /* esc */, 0x02, 0x010 /* esc */, 0x03,
        0x03 // Suffix
    };
    const std::size_t BufSize = std::extent<decltype(Buf)>::value;

    WrapPseudoMsg pseudoMsg;
    WrapFrame wrapFrame;

    auto readIter = &Buf[0];
    auto es = wrapFrame.read(pseudoMsg, readIter, BufSize);
    TS_ASSERT_EQUALS(es, comms::ErrorStatus::Success);
    auto& dataVec = pseudoMsg.field_data().value();
    postProcessRead(dataVec);

    Frame frame;
    Frame::MsgPtr msgPtr;

    auto iter = comms::readIteratorFor<Interface>(dataVec.data());
    es = frame.read(msgPtr, iter, dataVec.size());
    TS_ASSERT_EQUALS(es, comms::ErrorStatus::Success);
    TS_ASSERT(msgPtr);
    TS_ASSERT_EQUALS(msgPtr->getId(), test55::prot::MsgId_M1);

    auto* msg1 = static_cast<const ProtMsg1*>(msgPtr.get());
    TS_ASSERT_EQUALS(msg1->field_f1().value(), 0x0203);

    std::vector<std::uint8_t> outputBuf;
    outputBuf.resize(frame.length(*msg1));
    auto writeIter = comms::writeIteratorFor<Interface>(outputBuf.data());
    es = frame.write(*msgPtr, writeIter, outputBuf.size());
    TS_ASSERT_EQUALS(es, comms::ErrorStatus::Success);

    postProcessWrite(outputBuf);
    comms::util::assign(pseudoMsg.field_data().value(), outputBuf.begin(), outputBuf.end());

    std::vector<std::uint8_t> finalOutputBuf;
    auto finalWriteIter = std::back_inserter(finalOutputBuf);
    es = wrapFrame.write(pseudoMsg, finalWriteIter, finalOutputBuf.max_size());
    if (es == comms::ErrorStatus::UpdateRequired) {
        auto updateIter = finalOutputBuf.data();
        es = wrapFrame.update(pseudoMsg, updateIter, finalOutputBuf.size());
    }
    TS_ASSERT_EQUALS(es, comms::ErrorStatus::Success);

    TS_ASSERT(std::equal(finalOutputBuf.begin(), finalOutputBuf.end(), std::begin(Buf) + 3U));
}
